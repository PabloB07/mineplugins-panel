generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  image         String?
  role          UserRole   @default(CUSTOMER)
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  downloads     Download[]
  licenses      License[]
  orders        Order[]
  sessions      Session[]
  
  // Admin activity relations
  adminActivities AdminActivityLog[] @relation("AdminActivityAdmin")
  targetActivities AdminActivityLog[] @relation("AdminActivityTarget")
  
  // Transfer relations
  sentTransfers LicenseTransfer[] @relation("TransferFrom")
  receivedTransfers LicenseTransfer[] @relation("TransferTo")

  // Support ticket relations
  supportTickets SupportTicket[] @relation("TicketUser")
  assignedTickets SupportTicket[] @relation("TicketAssignedTo")
  supportMessages SupportMessage[]

  // Discount relations
  discountUsages DiscountUsage[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id                  String          @id @default(cuid())
  name                String
  slug                String          @unique
  description         String?
  image               String?
  icon                String?
  price               Int
  salePrice           Int?
  defaultDurationDays Int             @default(365)
  maxActivations      Int             @default(1)
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  priceUSD            Float
  priceCLP            Float
  salePriceUSD        Float?
  salePriceCLP        Float?
  licenses            License[]
  orders              OrderItem[]
  versions            PluginVersion[]
  apiToken            String?         @unique
  discountCodes       DiscountCode[]

  @@index([slug])
  @@index([apiToken])
}

model PluginVersion {
  id             String     @id @default(cuid())
  productId      String
  version        String
  changelog      String?
  downloadUrl    String
  fileName       String?
  fileSize       Int
  minJavaVersion String?
  minMcVersion   String?
  isBeta         Boolean    @default(false)
  isLatest       Boolean    @default(false)
  isMandatory    Boolean    @default(false)
  publishedAt    DateTime   @default(now())
  createdAt      DateTime   @default(now())
  downloads      Download[]
  product        Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, version])
  @@index([productId, isLatest])
}

model License {
  id              String              @id @default(cuid())
  licenseKey      String              @unique
  userId          String
  productId       String
  status          LicenseStatus       @default(ACTIVE)
  createdAt       DateTime            @default(now())
  expiresAt       DateTime
  lastValidatedAt DateTime?
  maxActivations  Int                 @default(1)
  notes           String?
  product         Product             @relation(fields: [productId], references: [id])
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  activations     LicenseActivation[]
  order           OrderItem?

  @@index([licenseKey])
  @@index([userId])
  @@index([status, expiresAt])
}

model LicenseActivation {
  id               String   @id @default(cuid())
  licenseId        String
  serverId         String
  macAddress       String?
  hardwareHash     String?
  networkSignature String?
  serverIp         String?
  serverVersion    String?
  minecraftVersion String?
  serverName       String?
  serverPort       Int?
  motd             String?
  onlineMode       Boolean?
  maxPlayers       Int?
  onlinePlayers    Int?
  tps              Float?   // Ticks per second
  memoryUsage      Int?     // Memory usage in MB
  plugins          String? // JSON string array of plugins
  isActive         Boolean  @default(true)
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  validationCount  Int      @default(1)
  license          License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, serverId])
  @@index([serverId])
  @@index([licenseId, isActive])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(FLOW_CL)
  subtotal        Int
  discount        Int           @default(0)
  total           Int
  flowToken       String?       @unique
  flowOrderNumber String?
  flowPaymentUrl  String?
  customerEmail   String
  customerName    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paidAt          DateTime?
  currency        String        @default("CLP") @db.VarChar(3)
  subtotalUSD     Float?
  subtotalCLP     Float
  discountUSD     Float?        @default(0)
  discountCLP     Float         @default(0)
  totalUSD        Float?
  totalCLP        Float
  discountCodeId  String?
  user            User          @relation(fields: [userId], references: [id])
  items           OrderItem[]
  discountCode    DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  discountUsage   DiscountUsage?

  @@index([orderNumber])
  @@index([flowToken])
  @@index([userId])
  @@index([status])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  licenseId    String?  @unique
  unitPrice    Int
  quantity     Int      @default(1)
  durationDays Int
  currency     String   @default("CLP") @db.VarChar(3)
  unitPriceUSD Float?
  unitPriceCLP Float
  license      License? @relation(fields: [licenseId], references: [id])
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])
}

model Download {
  id           String        @id @default(cuid())
  userId       String
  versionId    String
  ipAddress    String?
  userAgent    String?
  downloadedAt DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id])
  version      PluginVersion @relation(fields: [versionId], references: [id])

  @@index([userId])
  @@index([versionId])
  @@index([downloadedAt])
}

model ValidationLog {
  id            String   @id @default(cuid())
  licenseKey    String
  serverId      String
  serverVersion String?
  isValid       Boolean
  failureReason String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([licenseKey])
  @@index([createdAt])
}

model AnalyticsSummary {
  id                    String   @id @default(cuid())
  date                  DateTime @unique @db.Date
  totalLicenses         Int      @default(0)
  activeLicenses        Int      @default(0)
  newLicenses           Int      @default(0)
  expiredLicenses       Int      @default(0)
  totalActivations      Int      @default(0)
  uniqueServers         Int      @default(0)
  totalRevenue          Int      @default(0)
  newOrders             Int      @default(0)
  totalValidations      Int      @default(0)
  successfulValidations Int      @default(0)
  failedValidations     Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  totalRevenueUSD       Float    @default(0)
  totalRevenueCLP       Float    @default(0)

  @@index([date])
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  FLOW_CL
  PAYKU
  TEBEX
  PAYPAL
  FREE_LICENSE
  ADMIN_GRANT
}

model LicenseTransfer {
  id               String   @id @default(cuid())
  originalLicenseId String
  newLicenseId    String
  fromUserId      String
  toUserId        String
  transferredAt   DateTime @default(now())
  
  fromUser        User     @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUser          User     @relation("TransferTo", fields: [toUserId], references: [id])

  @@map("license_transfers")
}

model AdminActivityLog {
  id        String   @id @default(cuid())
  adminId    String
  action     String
  details    String?
  targetUserId String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  admin     User     @relation("AdminActivityAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser User?    @relation("AdminActivityTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@map("admin_activity_logs")
}

enum GatewayEnvironment {
  SANDBOX
  PRODUCTION
}

model PaymentGatewayConfig {
  id                String             @id
  paykuApiToken     String?
  paykuSecretKey    String?
  paykuEnvironment  GatewayEnvironment @default(SANDBOX)
  tebexStoreId      String?
  tebexSecretKey    String?
  tebexEnvironment  GatewayEnvironment @default(PRODUCTION)
  paypalClientId    String?
  paypalClientSecret String?
  paypalWebhookId   String?
  paypalEnvironment GatewayEnvironment @default(SANDBOX)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model ServerStatus {
  id          String   @id @default(cuid())
  name        String
  ip          String   @unique
  port        Int      @default(25565)
  isOnline    Boolean  @default(false)
  lastChecked DateTime?
  status      String   @default("active")
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DiscountCode {
  id                String            @id @default(cuid())
  code              String            @unique
  type              DiscountType      @default(PERCENTAGE)
  value             Int
  currency          String            @default("CLP") @db.VarChar(3)
  minPurchase       Int?
  maxUses           Int?
  usedCount         Int               @default(0)
  maxUsesPerUser    Int?
  productId         String?
  startsAt          DateTime?
  expiresAt         DateTime?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  product           Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  usages            DiscountUsage[]
  orders            Order[]

  @@index([code])
  @@index([productId])
}

model DiscountUsage {
  id              String      @id @default(cuid())
  discountCodeId  String
  userId          String
  orderId         String      @unique
  discountAmount  Int
  createdAt       DateTime    @default(now())
  discountCode    DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id])
  order           Order       @relation(fields: [orderId], references: [id])

  @@index([discountCodeId])
  @@index([userId])
}

model SupportTicket {
  id            String            @id @default(cuid())
  ticketNumber  String            @unique
  userId        String
  subject       String
  description   String
  status        TicketStatus      @default(OPEN)
  priority      TicketPriority    @default(MEDIUM)
  category      TicketCategory    @default(GENERAL)
  assignedToId  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  closedAt      DateTime?
  user          User              @relation("TicketUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo    User?             @relation("TicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages      SupportMessage[]

  @@index([ticketNumber])
  @@index([userId])
  @@index([status])
}

model SupportMessage {
  id          String        @id @default(cuid())
  ticketId    String
  userId      String
  content     String
  isAdmin     Boolean       @default(false)
  isInternal  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([userId])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_REPLY
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  GENERAL
  LICENSE
  PAYMENT
  TECHNICAL
  REFUND
  BUG_REPORT
}
